{
	"schemaVersion": 1,
	"id": "nostalgic-versions",
	"version": "${version}",
	"name": "Nostalgic Versions",
	"description": "A port of Minecraft Alpha 1.1.2_01 into Fabric 1.20.1 in the form of a custom dimension.",
	"authors": [
		"NoIAmNotARobot1"
	],
	"license": "Unlicense",
	"icon": "assets/nostalgic-versions/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
          "net.noiamnotarobot.nostalgicversions.NostalgicVersions"
		],
        "client": [
          "net.noiamnotarobot.nostalgicversions.client.NostalgicVersionsClient"
        ],
		"fabric-datagen": [
          "net.noiamnotarobot.nostalgicversions.NostalgicVersionsDataGenerator"
		]
	},
	"mixins": [
		"nostalgic-versions.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.18.6",
		"minecraft": "~1.20.1",
		"java": ">=17",
		"fabric-api": "*"
